{%- comment -%}
  Terrian — Shop (collection) section.
  Drop this into a Shopify theme under /sections/ and assign it to a collection
  template (e.g. templates/collection.terrian.json) or the "All products" collection.
  It renders a hero, a marquee, a featured product, category filters, and a product
  grid — the same design as the local /shop/ mock, powered by real Liquid product data.
{%- endcomment -%}

{%- liquid
  assign coll = section.settings.collection | default: collections.all
  assign feat = section.settings.featured_product | default: coll.products.first
-%}

{%- style -%}
  #shop-{{ section.id }}{ --ink:#141312; --ink2:#1b1a18; --cream:#f3f1e9; --muted:#b7b2a6; --pink:#e29ee3; --line:rgba(243,241,233,.16);
    background:var(--ink); color:var(--cream); }
  #shop-{{ section.id }} .wrap{ max-width:1200px; margin:0 auto; padding:0 30px; }
  #shop-{{ section.id }} .eyebrow{ font:700 12px/1 system-ui,sans-serif; letter-spacing:.24em; text-transform:uppercase; color:var(--pink); }
  #shop-{{ section.id }} .shop-hero{ padding:120px 0 20px; }
  #shop-{{ section.id }} .shop-hero h1{ font-weight:800; letter-spacing:-.02em; text-transform:uppercase; line-height:.9; font-size:clamp(64px,14vw,190px); margin:10px 0 0; }
  #shop-{{ section.id }} .shop-hero .sub{ color:var(--muted); max-width:520px; margin-top:18px; font-size:18px; }
  #shop-{{ section.id }} .marquee{ overflow:hidden; border-top:1px solid var(--line); border-bottom:1px solid var(--line); background:var(--pink); color:var(--ink); margin-top:34px; }
  #shop-{{ section.id }} .marquee__row{ display:flex; white-space:nowrap; animation:mq 26s linear infinite; }
  #shop-{{ section.id }} .marquee span{ font:800 14px/1 system-ui,sans-serif; letter-spacing:.14em; text-transform:uppercase; padding:12px 22px; }
  @keyframes mq{ to{ transform:translateX(-50%); } }
  #shop-{{ section.id }} .featured{ padding:90px 0; }
  #shop-{{ section.id }} .featured__wrap{ max-width:1200px; margin:0 auto; padding:0 30px; display:grid; grid-template-columns:1.05fr .95fr; gap:60px; align-items:center; }
  #shop-{{ section.id }} .featured__img{ position:relative; border-radius:18px; overflow:hidden; aspect-ratio:4/5; background:var(--ink2); }
  #shop-{{ section.id }} .featured__img img{ width:100%; height:100%; object-fit:cover; }
  #shop-{{ section.id }} .featured__tag{ position:absolute; top:16px; left:16px; background:var(--ink); color:var(--cream); font:700 11px/1 system-ui,sans-serif; letter-spacing:.16em; text-transform:uppercase; padding:9px 14px; border-radius:999px; }
  #shop-{{ section.id }} .featured h2{ font-weight:800; text-transform:uppercase; letter-spacing:-.02em; line-height:.98; font-size:clamp(38px,5.5vw,72px); margin:16px 0 18px; }
  #shop-{{ section.id }} .featured p{ color:var(--muted); max-width:440px; margin-bottom:22px; }
  #shop-{{ section.id }} .fp{ display:flex; align-items:baseline; gap:12px; font-size:24px; margin-bottom:26px; }
  #shop-{{ section.id }} .fp .was{ color:var(--muted); text-decoration:line-through; font-size:18px; }
  #shop-{{ section.id }} .btn{ display:inline-flex; align-items:center; gap:10px; font:700 13px/1 system-ui,sans-serif; letter-spacing:.06em; text-transform:uppercase; padding:15px 26px; border-radius:999px; background:var(--cream); color:var(--ink); text-decoration:none; }
  #shop-{{ section.id }} .shop-bar{ max-width:1200px; margin:0 auto; padding:0 30px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
  #shop-{{ section.id }} .shop-bar h2{ font-weight:800; text-transform:uppercase; font-size:clamp(28px,4vw,44px); }
  #shop-{{ section.id }} .filters{ display:flex; gap:8px; flex-wrap:wrap; }
  #shop-{{ section.id }} .filter{ background:transparent; border:1px solid var(--line); color:var(--cream); border-radius:999px; padding:10px 18px; font:700 12px/1 system-ui,sans-serif; letter-spacing:.06em; text-transform:uppercase; cursor:pointer; }
  #shop-{{ section.id }} .filter.is-active{ background:var(--cream); color:var(--ink); border-color:var(--cream); }
  #shop-{{ section.id }} .pgrid{ max-width:1200px; margin:26px auto 0; padding:0 30px 90px; display:grid; grid-template-columns:repeat(3,1fr); gap:28px 26px; }
  #shop-{{ section.id }} .pc{ display:flex; flex-direction:column; color:var(--cream); text-decoration:none; }
  #shop-{{ section.id }} .pc__img{ position:relative; border-radius:14px; overflow:hidden; aspect-ratio:4/5; background:var(--ink2); }
  #shop-{{ section.id }} .pc__img img{ width:100%; height:100%; object-fit:cover; transition:transform .5s ease, opacity .4s ease; }
  #shop-{{ section.id }} .pc__img img.alt{ position:absolute; inset:0; opacity:0; }
  #shop-{{ section.id }} .pc:hover .pc__img img{ transform:scale(1.04); }
  #shop-{{ section.id }} .pc:hover .pc__img img.alt{ opacity:1; }
  #shop-{{ section.id }} .pc__badge{ position:absolute; top:12px; left:12px; background:var(--pink); color:var(--ink); font:700 10px/1 system-ui,sans-serif; letter-spacing:.12em; text-transform:uppercase; padding:7px 11px; border-radius:999px; }
  #shop-{{ section.id }} .pc__cat{ font:700 11px/1 system-ui,sans-serif; letter-spacing:.14em; text-transform:uppercase; color:var(--pink); }
  #shop-{{ section.id }} .pc__title{ font:italic 600 20px/1.2 Georgia,serif; margin:8px 0; }
  #shop-{{ section.id }} .pc__price{ display:flex; gap:10px; align-items:baseline; font-size:16px; }
  #shop-{{ section.id }} .pc__price .was{ color:var(--muted); text-decoration:line-through; font-size:14px; }
  #shop-{{ section.id }} .pc.is-hidden{ display:none; }
  @media (max-width:920px){ #shop-{{ section.id }} .featured__wrap{ grid-template-columns:1fr; } #shop-{{ section.id }} .pgrid{ grid-template-columns:repeat(2,1fr); } }
{%- endstyle -%}

<div id="shop-{{ section.id }}">
  <section class="shop-hero"><div class="wrap">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="sub">{{ section.settings.subtitle }}</p>
  </div></section>

  {%- if section.settings.marquee != blank -%}
    {%- assign items = section.settings.marquee | split: ',' -%}
    <div class="marquee"><div class="marquee__row">
      {%- for pass in (1..2) -%}<div>{%- for it in items -%}<span>{{ it | strip }}</span><span>&bull;</span>{%- endfor -%}</div>{%- endfor -%}
    </div></div>
  {%- endif -%}

  {%- if feat -%}
  <section class="featured"><div class="featured__wrap">
    <div class="featured__img"><span class="featured__tag">Featured</span>
      <img src="{{ feat.featured_image | image_url: width: 900 }}" alt="{{ feat.title | escape }}" loading="lazy" width="900" height="1125">
    </div>
    <div>
      <p class="eyebrow">{{ feat.type | default: 'Merch' }}</p>
      <h2>{{ feat.title }}</h2>
      <p>{{ feat.description | strip_html | truncatewords: 26 }}</p>
      <div class="fp">
        {%- if feat.compare_at_price > feat.price -%}<span class="was">{{ feat.compare_at_price | money }}</span>{%- endif -%}
        <span class="now">{{ feat.price | money }}</span>
      </div>
      <a class="btn" href="{{ feat.url }}">Shop this &rarr;</a>
    </div>
  </div></section>
  {%- endif -%}

  <div class="shop-bar">
    <h2>All Products</h2>
    <div class="filters" role="tablist">
      <button class="filter is-active" data-filter="All">All</button>
      {%- assign types = coll.products | map: 'type' | uniq -%}
      {%- for t in types -%}{%- if t != blank -%}<button class="filter" data-filter="{{ t | escape }}">{{ t }}</button>{%- endif -%}{%- endfor -%}
    </div>
  </div>

  <section class="pgrid" id="pgrid-{{ section.id }}">
    {%- for product in coll.products -%}
      <a class="pc" data-cat="{{ product.type | escape }}" href="{{ product.url }}">
        <div class="pc__img">
          <img src="{{ product.featured_image | image_url: width: 700 }}" alt="{{ product.title | escape }}" loading="lazy" width="700" height="875">
          {%- if product.images[1] -%}<img class="alt" src="{{ product.images[1] | image_url: width: 700 }}" alt="" loading="lazy">{%- endif -%}
          {%- if product.compare_at_price > product.price -%}<span class="pc__badge">Sale</span>{%- endif -%}
          {%- unless product.available -%}<span class="pc__badge">Sold out</span>{%- endunless -%}
        </div>
        <div class="pc__info">
          <span class="pc__cat">{{ product.type | default: 'Merch' }}</span>
          <h3 class="pc__title">{{ product.title }}</h3>
          <div class="pc__price">
            {%- if product.compare_at_price > product.price -%}<span class="was">{{ product.compare_at_price | money }}</span>{%- endif -%}
            <span class="now">{{ product.price | money }}</span>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </section>
</div>

<script>
  (function(){
    var root=document.getElementById('shop-{{ section.id }}');
    var cards=[].slice.call(root.querySelectorAll('.pc'));
    root.querySelectorAll('.filter').forEach(function(btn){
      btn.addEventListener('click',function(){
        root.querySelectorAll('.filter').forEach(function(b){b.classList.remove('is-active');});
        btn.classList.add('is-active');
        var f=btn.getAttribute('data-filter');
        cards.forEach(function(c){ c.classList.toggle('is-hidden', f!=='All' && c.getAttribute('data-cat')!==f); });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Terrian Shop",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection (defaults to All products)" },
    { "type": "product", "id": "featured_product", "label": "Featured product (defaults to first in collection)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Shop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Merch" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Official Terrian apparel, accessories, and music. Wear the testimony." },
    { "type": "text", "id": "marquee", "label": "Marquee (comma-separated)", "default": "Official Merch, Mad Big World, Ships Worldwide, New Drop, Wear the Testimony" }
  ],
  "presets": [{ "name": "Terrian Shop" }]
}
{% endschema %}
